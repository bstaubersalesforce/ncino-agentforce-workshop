    <type>Lookup</type>
    <referenceTo>Account</referenceTo>
    <relationshipLabel>Covenant Monitors</relationshipLabel>
    <relationshipName>Covenant_Monitors</relationshipName>
    <required>false</required>
    <deleteConstraint>SetNull</deleteConstraint>
</CustomField>
