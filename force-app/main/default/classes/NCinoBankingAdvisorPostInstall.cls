// Generated by pie-poc-forge — MCP postInstall handler (REQUIRED for shipping MCP in 2GP).
// Works around known issue W-21685162: the packaged UserExternalCredential read permission is
// silently dropped on install, and the MCP perm set is not assigned to the Platform Integration
// User. Without this, subscribers' MCP tools are invisible to the Plan Tracer and calls fail.
// Ref: github.com/mvogelgesang/sf-mcp-registration-api-key (*PostInstall.cls).
global with sharing class NCinoBankingAdvisorPostInstall implements InstallHandler {

    private static final String MCP_PERM_SET = 'NCinoBankingAdvisor_Perm_Set';

    global void onInstall(InstallContext context) {
        try {
            // 1. The Platform Integration User makes all callouts from SF to the MCP server.
            List<User> platformUsers = [
                SELECT Id FROM User WHERE Name LIKE 'Platform%' AND IsActive = true LIMIT 1
            ];
            if (platformUsers.isEmpty()) {
                return; // nothing to assign to yet; admin can re-run via a setup action
            }
            Id platformUserId = platformUsers[0].Id;

            // 2. Assign the MCP permission set to the Platform Integration User.
            List<PermissionSet> ps = [
                SELECT Id FROM PermissionSet WHERE Name = :MCP_PERM_SET LIMIT 1
            ];
            if (!ps.isEmpty()) {
                Boolean already = ![
                    SELECT Id FROM PermissionSetAssignment
                    WHERE AssigneeId = :platformUserId AND PermissionSetId = :ps[0].Id LIMIT 1
                ].isEmpty();
                if (!already) {
                    insert new PermissionSetAssignment(
                        AssigneeId = platformUserId, PermissionSetId = ps[0].Id
                    );
                }
            }

            // 3. TODO (build): re-grant UserExternalCredential read to the Platform Integration User.
            // The packaged object-permission on the perm set is dropped on install (W-21685162),
            // so a separate perm set granting UserExternalCredential read must be created/assigned
            // here. Left as a build step — see refs/mcp-integration.md.
        } catch (Exception e) {
            // Do not let install fail; log for the admin to remediate.
            System.debug(LoggingLevel.ERROR, 'NCinoBankingAdvisor postInstall: ' + e.getMessage());
        }
    }
}
