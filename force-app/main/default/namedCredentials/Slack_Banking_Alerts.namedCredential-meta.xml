<?xml version="1.0" encoding="UTF-8"?>
<!-- Legacy anonymous Named Credential for the one-way Slack breach-alert webhook.
     SECURITY: the real Slack Incoming Webhook URL is a secret and is NOT stored here.
     This deploys a placeholder; enter the real webhook URL post-deploy per org
     (Setup -> Named Credentials -> Slack_Banking_Alerts -> Edit -> URL). See post-config step 6.
     Anonymous / No Authentication: a Slack webhook needs no auth and rejects an Authorization header. -->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <calloutStatus>Enabled</calloutStatus>
    <endpoint>https://hooks.slack.com/services/REPLACE_WITH_REAL_WEBHOOK_PATH</endpoint>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <label>Slack Banking Alerts</label>
    <principalType>Anonymous</principalType>
    <protocol>NoAuthentication</protocol>
</NamedCredential>
